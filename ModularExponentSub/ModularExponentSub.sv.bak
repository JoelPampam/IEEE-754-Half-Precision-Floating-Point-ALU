module ModularExponentSub #(parameter N = 8)
(
	input [N-1:0] A, B,
	output [N-1:0] out
);

	logic [N-1:0] R,Bcomp;
	logic Cout;
	
	RippleCarrySub #(.N(8)) RippleCarrySub_inst
	(
		.A(A) ,	// input [(N-1):0] A_sig
		.B(B) ,	// input [(N-1):0] B_sig
		.R(R) ,	// output [(N-1):0] R_sig
		.Cout(Cout) 	// output  Cout_sig
	);
	
	TwosCompConverter #(.N(8)) TwosCompConverter_inst
	(
		.R(R) ,	// input [(N-1):0] R_sig
		.B(Bcomp) 	// output [(N-1):0] B_sig
	);
	
	twotoonemux #(.N(8))twotoonemux_inst
	(
		.A(R) ,	// input [(N-1):0] A_sig
		.B(Bcomp) ,	// input [(N-1):0] B_sig
		.select(Cout) ,	// input  select_sig
		.out(out) 	// output [(N-1):0] out_sig
	);
	
endmodule